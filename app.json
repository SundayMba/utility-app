{
  "expo": {
    "name": "Smart Utility Toolkit",
    "slug": "smart-utility-toolkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smartutilitytoolkit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hng14.smartutilitytoolkit"
    },
    "android": {
      "package": "com.hng14.smartutilitytoolkit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F4F7FB"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F4F7FB",
          "image": "./assets/images/native-splash-mark.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "description": "A polished mobile toolkit for conversion, notes, and everyday calculators.",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43f72d6b-893b-4570-bfd4-d7f936bae134"
      }
    },
    "owner": "mba001"
  }
}
